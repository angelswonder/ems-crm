# Supabase Configuration
# Use the base Supabase URL only. Do not append /rest/v1 or /auth/v1 to this value.
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Payment Configuration
# Choose your payment provider: 'stripe' or 'paystack'
VITE_PAYMENT_PROVIDER=stripe

# Stripe Configuration (if using Stripe)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Paystack Configuration (if using Paystack)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Note: Keep your secret keys on the server-side only!
# Never expose secret keys in client-side environment variables.